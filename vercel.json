{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://colombiansofture.com:30199/api/:path*"
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|svg|ico|json|woff2))$",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}